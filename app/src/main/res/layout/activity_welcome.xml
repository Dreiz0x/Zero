<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0F"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <ImageView android:id="@+id/imgVoeLogo" android:layout_width="120dp" android:layout_height="48dp" android:layout_marginBottom="4dp" android:src="@android:color/transparent" android:contentDescription="VOE"/>
            <ImageView android:id="@+id/imgTitulo" android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginBottom="24dp" android:src="@android:color/transparent" android:contentDescription="Título"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:orientation="horizontal" android:background="#1AFFFFFF" android:paddingVertical="16dp" android:paddingEnd="12dp">
                <View android:layout_width="3dp" android:layout_height="match_parent" android:layout_marginEnd="12dp" android:background="#E53935"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_marginEnd="10dp" android:src="@drawable/ic_a_chat"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A." android:textColor="#E53935" android:textSize="18sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Habilidades transversales de lenguaje y comunicación" android:textColor="#FFFFFF" android:textSize="12sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_book"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1. Comprensión lectora" android:textColor="#E53935" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Ámbito de estudio\n• Ámbito literario\n• Ámbito de participación social" android:textColor="#CCCCCC" android:textSize="11sp" android:layout_marginBottom="10dp" android:lineSpacingExtra="2dp"/>

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_edit"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2. Redacción indirecta" android:textColor="#E53935" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Ámbito de estudio\n• Ámbito de participación social" android:textColor="#CCCCCC" android:textSize="11sp" android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:orientation="horizontal" android:background="#1AFFFFFF" android:paddingVertical="16dp" android:paddingEnd="12dp">
                <View android:layout_width="3dp" android:layout_height="match_parent" android:layout_marginEnd="12dp" android:background="#1E88E5"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_marginEnd="10dp" android:src="@drawable/ic_b_calc"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="B." android:textColor="#1E88E5" android:textSize="18sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Competencia matemática" android:textColor="#FFFFFF" android:textSize="12sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <View android:layout_width="6dp" android:layout_height="6dp" android:layout_marginEnd="8dp" android:background="#1E88E5"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1. Competencia matemática" android:textColor="#1E88E5" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Teoría de conjuntos\n• Aritmética\n• Álgebra\n• Probabilidad\n• Estadística\n• Gráficos y tablas" android:textColor="#CCCCCC" android:textSize="11sp" android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:orientation="horizontal" android:background="#1AFFFFFF" android:paddingVertical="16dp" android:paddingEnd="12dp">
                <View android:layout_width="3dp" android:layout_height="match_parent" android:layout_marginEnd="12dp" android:background="#43A047"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_marginEnd="10dp" android:src="@drawable/ic_c_institution"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="C." android:textColor="#43A047" android:textSize="18sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sistema Político y Electoral Mexicano" android:textColor="#FFFFFF" android:textSize="12sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_person"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1. Sistema Político Mexicano" android:textColor="#43A047" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Modelo constitucional\n• Poder Judicial\n• Ciudadanía\n• Sistema de partidos en México" android:textColor="#CCCCCC" android:textSize="11sp" android:layout_marginBottom="10dp" android:lineSpacingExtra="2dp"/>

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_ballot"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2. Sistema Electoral Mexicano" android:textColor="#43A047" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Principios del sistema electoral\n• Tipos de sistemas electorales\n• Autoridades electorales\n• Delitos electorales\n• Candidaturas independientes\n• Proceso Electoral Federal" android:textColor="#CCCCCC" android:textSize="11sp" android:layout_marginBottom="10dp" android:lineSpacingExtra="2dp"/>

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_shield"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3. Instituto Nacional Electoral" android:textColor="#43A047" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Conocimientos fundamentales del INE\n• Órganos del INE\n• SPEN" android:textColor="#CCCCCC" android:textSize="11sp" android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:orientation="horizontal" android:background="#1AFFFFFF" android:paddingVertical="16dp" android:paddingEnd="12dp">
                <View android:layout_width="3dp" android:layout_height="match_parent" android:layout_marginEnd="12dp" android:background="#F5C400"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="28dp" android:layout_height="28dp" android:layout_marginEnd="10dp" android:src="@drawable/ic_d_briefcase"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D." android:textColor="#F5C400" android:textSize="18sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Conocimientos técnicos inherentes al cargo" android:textColor="#FFFFFF" android:textSize="12sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_org"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1. Estructura del INE" android:textColor="#F5C400" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Direcciones ejecutivas\n• Juntas locales y distritales\n• Consejos locales y distritales" android:textColor="#CCCCCC" android:textSize="11sp" android:layout_marginBottom="10dp" android:lineSpacingExtra="2dp"/>

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_calendar"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2. Proceso electoral" android:textColor="#F5C400" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Preparación de la elección\n• Modalidades de voto anticipado\n• Proceso electoral del Poder Judicial\n• Atribuciones especiales del INE\n• Jornada electoral" android:textColor="#CCCCCC" android:textSize="11sp" android:layout_marginBottom="10dp" android:lineSpacingExtra="2dp"/>

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_scales"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3. Justicia electoral" android:textColor="#F5C400" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Delitos electorales\n• Medios de impugnación\n• Violencia política contra las mujeres por razón de género" android:textColor="#CCCCCC" android:textSize="11sp" android:layout_marginBottom="10dp" android:lineSpacingExtra="2dp"/>

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_box"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4. Organización de la elección" android:textColor="#F5C400" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Observadores electorales\n• Casillas electorales\n• Documentación y materiales electorales" android:textColor="#CCCCCC" android:textSize="11sp" android:layout_marginBottom="10dp" android:lineSpacingExtra="2dp"/>

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_clipboard"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5. Resultados y declaración de validez" android:textColor="#F5C400" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Remisión de documentación\n• Cómputos distritales" android:textColor="#CCCCCC" android:textSize="11sp" android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout android:layout_width="match_parent" android:layout_height="64dp" android:background="#141414" android:gravity="center" android:orientation="vertical">
        <View android:layout_width="8dp" android:layout_height="8dp" android:layout_marginBottom="4dp" android:background="#FFFFFF"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Curriculum" android:textColor="#FFFFFF" android:textSize="10sp" android:gravity="center"/>
    </LinearLayout>

</LinearLayout>

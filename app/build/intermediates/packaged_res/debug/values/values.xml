<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="vespa_bg">#070707</color>
    <color name="vespa_yellow">#F5C400</color>
    <color name="white">#FFFFFF</color>
    <style name="Theme.Vespa" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/vespa_yellow</item>
        <item name="colorOnPrimary">@color/vespa_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
    <style name="Theme.Vespa.Welcome" parent="Theme.Vespa">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>